// TCREMP prototype-embedding geometry (Appendix T, Fig. T.1). Render: dot -Tpdf.
digraph embedding {
  rankdir=LR;
  bgcolor="transparent";
  node  [fontname="Helvetica", fontsize=11, penwidth=1.1];
  edge  [fontname="Helvetica", fontsize=9, color="#555555"];

  subgraph cluster_pgen {
    label="prototypes  p_k ~ P_gen  (VDJ rearrangement model)";
    fontname="Helvetica"; fontsize=10; labeljust="l";
    style="rounded,dashed"; color="#7570B3";
    p1 [label="p₁", shape=circle, style=filled, fillcolor="#EAE6F3"];
    p2 [label="p₂", shape=circle, style=filled, fillcolor="#EAE6F3"];
    pd [label="…",  shape=plaintext];
    pK [label="p_K", shape=circle, style=filled, fillcolor="#EAE6F3"];
  }

  x   [label="receptor  x\n(V, J, CDR3)", shape=box, style="rounded,filled", fillcolor="#E1F0EC"];
  phi [label="landmark map\nφ(x)_k = d(x, p_k)", shape=box, style="rounded,filled", fillcolor="#FBE5D0"];
  emb [label="embedding\nℝ^{3K}  (V | J | junction)", shape=box, style=rounded];
  geo [label="‖φ(x)−φ(y)‖₂ ≈ d(x,y)\nPCA denoise", shape=box, style=rounded];
  clu [label="antigen-specific\nclusters", shape=box, style="rounded,filled", fillcolor="#EAE6F3"];

  {p1 p2 pK} -> phi [style=dashed, arrowsize=0.7, label="d(·,p_k)"];
  x   -> phi [label="gapblock / germline"];
  phi -> emb -> geo -> clu;
}
